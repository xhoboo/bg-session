# Copy this file to .env and fill in your Supabase project credentials.
# Find them in the Supabase dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://your-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Cloudflare Turnstile (CAPTCHA) site key — public, safe to expose.
# Get one free at https://dash.cloudflare.com → Turnstile.
# Leave empty to disable the CAPTCHA locally. To test the widget without a real
# account, use Cloudflare's always-pass test key: 1x00000000000000000000AA
# Whatever you set here must match the secret pasted in
# Supabase → Authentication → Attack Protection (CAPTCHA).
VITE_TURNSTILE_SITE_KEY=

# Sentry error monitoring (optional). Paste the project's DSN to turn on error
# reporting; leave empty to disable it entirely (Sentry isn't even loaded then).
# Create a project at https://sentry.io → Settings → Client Keys (DSN).
VITE_SENTRY_DSN=
